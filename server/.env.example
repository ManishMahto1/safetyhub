# Server port
PORT=7000

# MongoDB connection string (optional — API runs without it; used only for
# best-effort voice-interaction logging). Local example shown; use your Atlas
# URI in server/.env (which is git-ignored). NEVER put real credentials here.
MONGO_URI=Mongodb_uri_key


# OpenAI API key, used only by the voice-assist guidance endpoint.
OPENAI_API_KEY=your_openai_api_key

# Comma-separated list of allowed origins for CORS
CLIENT_ORIGIN=http://localhost:5173
